{
  "name": "purpletoadmail-mcp",
  "version": "2.0.3",
  "description": "Model Context Protocol server for PurpleToad Mail — send, receive, search, and manage email from any AI agent",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "purpletoadmail-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
